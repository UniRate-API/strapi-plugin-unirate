{
  "name": "strapi-plugin-unirate",
  "version": "0.1.0",
  "description": "Strapi v5 plugin for the UniRate currency-exchange API — server-side proxy routes (rate/convert/currencies/vat) and an injectable UniRate service. Zero runtime deps.",
  "type": "module",
  "license": "MIT",
  "author": "UniRate (https://unirateapi.com)",
  "homepage": "https://github.com/UniRate-API/strapi-plugin-unirate#readme",
  "bugs": "https://github.com/UniRate-API/strapi-plugin-unirate/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UniRate-API/strapi-plugin-unirate.git"
  },
  "keywords": [
    "strapi",
    "strapi-plugin",
    "strapi-v5",
    "unirate",
    "currency",
    "currency-converter",
    "exchange-rates",
    "forex",
    "fx",
    "vat",
    "fintech"
  ],
  "strapi": {
    "kind": "plugin",
    "name": "unirate",
    "displayName": "UniRate Currency Exchange",
    "description": "Exchange-rate proxy service and routes powered by UniRate API."
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "@strapi/strapi": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@strapi/strapi": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
